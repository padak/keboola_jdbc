{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "outDir": "out",
    "sourceMap": true,
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "lib": ["es6"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
